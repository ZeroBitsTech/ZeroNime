# -----------------------------------------------------------------------------
# Core server settings
# -----------------------------------------------------------------------------

# HTTP listen address for the API server.
ANIME_LISTEN_ADDR=:8080

# PostgreSQL connection string used for watchlist, history, and other persisted
# backend data.
DATABASE_URL=postgres://zeronime:zeronime%40123@localhost:5432/animedb?sslmode=disable

# Optional Redis configuration.
# Leave REDIS_ADDR empty to run without Redis.
REDIS_ADDR=localhost:6379
REDIS_PASSWORD=
REDIS_DB=0

# -----------------------------------------------------------------------------
# Provider configuration
# -----------------------------------------------------------------------------

# Active provider implementation.
ANIME_ACTIVE_PROVIDER=kuramanime

# Provider base URLs.
OTAKUDESU_BASE_URL=https://otakudesu.blog
KURAMANIME_BASE_URL=https://v17.kuramanime.ink

# Browser path for providers that need Chromium-based rendering.
# Leave empty if the runtime already provides a default browser path or if the
# active provider does not require it.
ANIME_BROWSER_PATH=

# Upstream timeout for provider and media requests.
ANIME_REQUEST_TIMEOUT=12s

# -----------------------------------------------------------------------------
# API and metadata cache settings
# -----------------------------------------------------------------------------

# General metadata cache TTL.
ANIME_CACHE_TTL=5m

# TTL for resolved stream metadata.
ANIME_STREAM_CACHE_TTL=6h

# TTL for proxied image cache.
ANIME_IMAGE_CACHE_TTL=24h

# Maximum time budget for browser-rendered provider operations.
ANIME_BROWSER_RENDER_BUDGET=2500ms

# Public and write rate limits, in requests per minute.
ANIME_PUBLIC_RATE_LIMIT_RPM=180
ANIME_WRITE_RATE_LIMIT_RPM=60

# -----------------------------------------------------------------------------
# Local media startup cache
# -----------------------------------------------------------------------------

# Local directory used to store media startup chunks.
ANIME_MEDIA_CACHE_DIR=./var/media-cache

# Number of bytes to cache from the beginning of each MP4.
ANIME_MEDIA_CACHE_HEAD_BYTES=10485760

# Number of bytes to cache from the end of each MP4.
ANIME_MEDIA_CACHE_TAIL_BYTES=2097152

# Timeout used while building startup cache from upstream media.
ANIME_MEDIA_CACHE_FETCH_TIMEOUT=20s

# -----------------------------------------------------------------------------
# Predictive next-episode cache
# -----------------------------------------------------------------------------

# Enable or disable the temporary next-episode startup cache.
ANIME_PREDICTIVE_CACHE_ENABLED=true

# Local directory used for predictive next-episode startup chunks.
ANIME_PREDICTIVE_CACHE_DIR=/tmp/zeronime-predictive-next

# Number of bytes to cache from the beginning of predictive startup media.
ANIME_PREDICTIVE_CACHE_HEAD_BYTES=6291456

# Number of bytes to cache from the end of predictive startup media.
ANIME_PREDICTIVE_CACHE_TAIL_BYTES=1048576

# -----------------------------------------------------------------------------
# Optional DObject / S3-compatible backing store
# -----------------------------------------------------------------------------

# DObject is optional.
# If these values are left empty, the backend runs in local-only cache mode.
# In that mode, startup chunks are stored only on local disk.
#
# If configured, DObject acts as a persistent backing store for startup chunks,
# allowing the backend to restore cache state after restarts or redeploys.

DOBJECT_URL=
DOBJECT_S3_ACCESS_KEY=
DOBJECT_S3_SECRET_KEY=

# Default bucket and region values can stay as-is even when DObject is disabled.
DOBJECT_BUCKET=zeronime-cache
DOBJECT_REGION=us-east-1

# S3 path-style access.
DOBJECT_FORCE_PATH=true

# Create the bucket automatically when the backend starts and the target object
# store supports it.
DOBJECT_AUTO_CREATE=true

# Set to true to enable DObject whenever the credentials above are valid.
# Keep false for local-only development.
DOBJECT_USE_WHEN_READY=false
